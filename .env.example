# Required
VOTER_PRIVATE_KEY=0x_your_bsc_testnet_private_key_here

# Required for Cournot pipeline (LLM-based evaluation)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional - wallet keystore password (default: cournot-voter)
# WALLET_PASSWORD=cournot-voter

# Optional - chain config (defaults shown)
# NETWORK=bsc-testnet
# RPC_URL=https://data-seed-prebsc-2-s2.binance.org:8545

# Optional - Cournot pipeline config
# COURNOT_LLM_PROVIDER=openai
# COURNOT_LLM_MODEL=gpt-4o
# CONFIDENCE_THRESHOLD=0.70

# Optional - daemon config
# POLL_INTERVAL=12
# AUTO_SETTLE=false
# POR_STORAGE_DIR=./por_artifacts
# LOG_LEVEL=INFO

# Optional - path to cournot-protocol repo (for pipeline imports)
# COURNOT_PROTOCOL_PATH=/path/to/cournot-protocol
